meta {
  name: Cắt PDF
  type: http
  seq: 5
}

post {
  url: {{base_url}}/api/split
  body: multipart-form
  auth: none
}

body:multipart-form {
  file: @file(/path/to/test.pdf)
  ranges: 1-2,3
}

# ranges: chuỗi kiểu "1-3,4,5-7"

tests {
  test("status 200", function() {
    expect(res.status).to.equal(200);
  });
  test("trả về ZIP", function() {
    expect(res.headers["content-type"]).to.include("application/zip");
  });
}
